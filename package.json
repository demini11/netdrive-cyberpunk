{
  "name": "netdrive-cyberpunk",
  "version": "1.0.0",
  "description": "NETDRIVE - Cyberpunk Photo & File Manager",
  "scripts": {
    "setup": "npm install && npx cap add android && npx cap sync android",
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "apk:debug": "cd android && ./gradlew assembleDebug",
    "apk:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
